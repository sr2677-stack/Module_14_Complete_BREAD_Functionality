cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.db
*.sqlite3
instance/
*.egg-info/
dist/
build/
.env
.venv/
venv/
env/

# Node / Playwright
node_modules/
playwright-report/
test-results/
.playwright/

# Docker
*.env
.dockerignore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# VS Code / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# GitHub Actions artifacts
artifacts/
EOF